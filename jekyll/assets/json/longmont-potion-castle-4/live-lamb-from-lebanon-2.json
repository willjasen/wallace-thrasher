[
  {
    "Index": 1,
    "Start Time": "00:00:00,000",
    "End Time": "00:00:02,000",
    "Speaker": "Man",
    "Text": "Wh... what's my name?"
  },
  {
    "Index": 2,
    "Start Time": "00:00:02,000",
    "End Time": "00:00:04,000",
    "Speaker": "LPC",
    "Text": "I can't do those information on the phone, sir."
  },
  {
    "Index": 3,
    "Start Time": "00:00:04,000",
    "End Time": "00:00:06,000",
    "Speaker": "LPC",
    "Text": "It's been UPS policy for like 12 years now."
  },
  {
    "Index": 4,
    "Start Time": "00:00:06,000",
    "End Time": "00:00:09,000",
    "Speaker": "Man",
    "Text": "What do you mean I ordered lambs? What the... what are you talking about?"
  },
  {
    "Index": 5,
    "Start Time": "00:00:09,000",
    "End Time": "00:00:13,000",
    "Speaker": "LPC",
    "Text": "The lamb. You ordered four or five lambs, from the Lebanon Center."
  },
  {
    "Index": 6,
    "Start Time": "00:00:13,000",
    "End Time": "00:00:16,000",
    "Speaker": "Man",
    "Text": "How... how do you know? You don't even know my name."
  },
  {
    "Index": 7,
    "Start Time": "00:00:16,000",
    "End Time": "00:00:19,000",
    "Speaker": "LPC",
    "Text": "I do, but I can't say it on the phone. That's just UPS policy."
  },
  {
    "Index": 8,
    "Start Time": "00:00:19,000",
    "End Time": "00:00:21,000",
    "Speaker": "Man",
    "Text": "What do you mean you can't say on the phone?"
  },
  {
    "Index": 9,
    "Start Time": "00:00:21,000",
    "End Time": "00:00:24,000",
    "Speaker": "LPC",
    "Text": "[chuckling] It's UPS policy, sir, it's been that way for twelve years now."
  },
  {
    "Index": 10,
    "Start Time": "00:00:24,000",
    "End Time": "00:00:25,000",
    "Speaker": "Man",
    "Text": "Are you nuts or something?"
  },
  {
    "Index": 11,
    "Start Time": "00:00:25,000",
    "End Time": "00:00:26,000",
    "Speaker": "LPC",
    "Text": "No."
  },
  {
    "Index": 12,
    "Start Time": "00:00:26,000",
    "End Time": "00:00:29,000",
    "Speaker": "LPC",
    "Text": "You, if you don't accept your package, you will have to least pay for freight."
  },
  {
    "Index": 13,
    "Start Time": "00:00:29,000",
    "End Time": "00:00:32,000",
    "Speaker": "SPEAKER_01",
    "Text": "to at least pay for freight, which is $98."
  },
  {
    "Index": 14,
    "Start Time": "00:00:32,000",
    "End Time": "00:00:34,000",
    "Speaker": "Man",
    "Text": "I don't know what you're talking about."
  },
  {
    "Index": 15,
    "Start Time": "00:00:34,000",
    "End Time": "00:00:36,000",
    "Speaker": "LPC",
    "Text": "A package of lambs, sir."
  },
  {
    "Index": 16,
    "Start Time": "00:00:36,000",
    "End Time": "00:00:38,000",
    "Speaker": "SPEAKER_01",
    "Text": "What address?"
  },
  {
    "Index": 17,
    "Start Time": "00:00:38,000",
    "End Time": "00:00:39,000",
    "Speaker": "SPEAKER_01",
    "Text": "The land center."
  },
  {
    "Index": 18,
    "Start Time": "00:00:39,000",
    "End Time": "00:00:40,000",
    "Speaker": "Man",
    "Text": "Huh?"
  },
  {
    "Index": 19,
    "Start Time": "00:00:40,000",
    "End Time": "00:00:42,000",
    "Speaker": "Man",
    "Text": "I mean, what address?"
  },
  {
    "Index": 20,
    "Start Time": "00:00:42,000",
    "End Time": "00:00:44,000",
    "Speaker": "LPC",
    "Text": "I can't, you know your own address, sir."
  },
  {
    "Index": 21,
    "Start Time": "00:00:44,000",
    "End Time": "00:00:45,000",
    "Speaker": "Man",
    "Text": "Yeah."
  },
  {
    "Index": 22,
    "Start Time": "00:00:45,000",
    "End Time": "00:00:50,000",
    "Speaker": "LPC",
    "Text": "It just doesn't have enough postage when would be the best time to come by and pick, drop it off to you."
  },
  {
    "Index": 23,
    "Start Time": "00:00:50,000",
    "End Time": "00:00:53,000",
    "Speaker": "Man",
    "Text": "Listen, you have the wrong-- '[beep]' --party."
  },
  {
    "Index": 24,
    "Start Time": "00:00:53,000",
    "End Time": "00:00:56,000",
    "Speaker": "LPC",
    "Text": "No, I'm not at a party, I need to bring you your lambs."
  },
  {
    "Index": 25,
    "Start Time": "00:00:56,000",
    "End Time": "00:00:57,000",
    "Speaker": "Man",
    "Text": "What?"
  },
  {
    "Index": 26,
    "Start Time": "00:00:57,000",
    "End Time": "00:00:58,000",
    "Speaker": "LPC",
    "Text": "I need to bring you your lambs, sir."
  },
  {
    "Index": 27,
    "Start Time": "00:00:58,000",
    "End Time": "00:01:00,000",
    "Speaker": "SPEAKER_01",
    "Text": "sir."
  },
  {
    "Index": 28,
    "Start Time": "00:01:00,000",
    "End Time": "00:01:02,000",
    "Speaker": "Man",
    "Text": "Are you crazy or what?"
  },
  {
    "Index": 29,
    "Start Time": "00:01:02,000",
    "End Time": "00:01:03,000",
    "Speaker": "LPC",
    "Text": "No."
  },
  {
    "Index": 30,
    "Start Time": "00:01:03,000",
    "End Time": "00:01:04,000",
    "Speaker": "Man",
    "Text": "Huh?"
  },
  {
    "Index": 31,
    "Start Time": "00:01:04,000",
    "End Time": "00:01:05,000",
    "Speaker": "LPC",
    "Text": "No, sir."
  },
  {
    "Index": 32,
    "Start Time": "00:01:05,000",
    "End Time": "00:01:08,000",
    "Speaker": "LPC",
    "Text": "I'm trying to do my job delivering the lambs that you ordered."
  },
  {
    "Index": 33,
    "Start Time": "00:01:08,000",
    "End Time": "00:01:10,000",
    "Speaker": "Man",
    "Text": "How do you know I ordered lambs?"
  },
  {
    "Index": 34,
    "Start Time": "00:01:10,000",
    "End Time": "00:01:11,000",
    "Speaker": "LPC",
    "Text": "You just said you did."
  },
  {
    "Index": 35,
    "Start Time": "00:01:11,000",
    "End Time": "00:01:12,000",
    "Speaker": "Man",
    "Text": "Huh?"
  },
  {
    "Index": 36,
    "Start Time": "00:01:12,000",
    "End Time": "00:01:13,000",
    "Speaker": "LPC",
    "Text": "You just said you ordered lambs."
  },
  {
    "Index": 37,
    "Start Time": "00:01:13,000",
    "End Time": "00:01:15,000",
    "Speaker": "Man",
    "Text": "I said, what are you talking about?"
  },
  {
    "Index": 38,
    "Start Time": "00:01:15,000",
    "End Time": "00:01:16,000",
    "Speaker": "Man",
    "Text": "Are you nuts?"
  },
  {
    "Index": 39,
    "Start Time": "00:01:16,000",
    "End Time": "00:01:18,000",
    "Speaker": "Man",
    "Text": "I don't know what's the..."
  },
  {
    "Index": 40,
    "Start Time": "00:01:18,000",
    "End Time": "00:01:20,000",
    "Speaker": "Man",
    "Text": "I don't know what's the matter with you."
  },
  {
    "Index": 41,
    "Start Time": "00:01:20,000",
    "End Time": "00:01:21,000",
    "Speaker": "SPEAKER_01",
    "Text": "What?"
  },
  {
    "Index": 42,
    "Start Time": "00:01:21,000",
    "End Time": "00:01:23,000",
    "Speaker": "Man",
    "Text": "What?"
  },
  {
    "Index": 43,
    "Start Time": "00:01:23,000",
    "End Time": "00:01:27,000",
    "Speaker": "LPC",
    "Text": "All that's the matter is that you won't... accept your package that you ordered, of lambs."
  },
  {
    "Index": 44,
    "Start Time": "00:01:27,000",
    "End Time": "00:01:28,000",
    "Speaker": "Man",
    "Text": "Listen."
  },
  {
    "Index": 45,
    "Start Time": "00:01:28,000",
    "End Time": "00:01:33,000",
    "Speaker": "Man",
    "Text": "I'm going to hang up. If you call again, I'm going to call cops, that's all."
  },
  {
    "Index": 46,
    "Start Time": "00:01:33,000",
    "End Time": "00:01:35,000",
    "Speaker": "LPC",
    "Text": "Well, there's only crime that's being committed by you."
  },
  {
    "Index": 47,
    "Start Time": "00:01:35,000",
    "End Time": "00:01:36,000",
    "Speaker": "Man",
    "Text": "What?"
  }
]
