  {
    "Index": 37,
    "Start Time": "00:01:18,600",
    "End Time": "00:01:18,880",
    "Speaker": "SPEAKER_00",
    "Text": "I'll look forward to it."
  },
  {
    "Index": 38,
    "Start Time": "00:01:18,880",
    "End Time": "00:01:20,260",
    "Speaker": "SPEAKER_00",
    "Text": "I'll look forward to getting up by."
  }
