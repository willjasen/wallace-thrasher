[
  {
    "Index": 1,
    "Start Time": "00:00:04,480",
    "End Time": "00:00:06,800",
    "Speaker": "SPEAKER_00",
    "Text": "Do you need a preacher to pray for you?"
  },
  {
    "Index": 2,
    "Start Time": "00:00:07,460",
    "End Time": "00:00:07,860",
    "Speaker": "SPEAKER_01",
    "Text": "Yeah."
  },
  {
    "Index": 3,
    "Start Time": "00:00:09,540",
    "End Time": "00:00:11,020",
    "Speaker": "SPEAKER_00",
    "Text": "What are you doing these days?"
  },
  {
    "Index": 4,
    "Start Time": "00:00:11,600",
    "End Time": "00:00:12,300",
    "Speaker": "SPEAKER_01",
    "Text": "Oh, whoa."
  },
  {
    "Index": 5,
    "Start Time": "00:00:12,640",
    "End Time": "00:00:13,640",
    "Speaker": "SPEAKER_01",
    "Text": "This is going to church."
  },
  {
    "Index": 6,
    "Start Time": "00:00:14,820",
    "End Time": "00:00:16,180",
    "Speaker": "SPEAKER_00",
    "Text": "What church you go to?"
  },
  {
    "Index": 7,
    "Start Time": "00:00:18,560",
    "End Time": "00:00:21,680",
    "Speaker": "SPEAKER_01",
    "Text": "It's called the Fellowship of the Hand of the Lord."
  },
  {
    "Index": 8,
    "Start Time": "00:00:22,420",
    "End Time": "00:00:25,500",
    "Speaker": "SPEAKER_00",
    "Text": "I think you're trying to pull my leg."
  },
  {
    "Index": 9,
    "Start Time": "00:00:25,780",
    "End Time": "00:00:25,920",
    "Speaker": "SPEAKER_01",
    "Text": "Huh?"
  },
  {
    "Index": 10,
    "Start Time": "00:00:26,820",
    "End Time": "00:00:27,840",
    "Speaker": "SPEAKER_01",
    "Text": "What are you doing?"
  },
  {
    "Index": 11,
    "Start Time": "00:00:29,060",
    "End Time": "00:00:29,860",
    "Speaker": "SPEAKER_01",
    "Text": "Pull your legs."
  },
  {
    "Index": 12,
    "Start Time": "00:00:30,680",
    "End Time": "00:00:31,900",
    "Speaker": "SPEAKER_00",
    "Text": "What did you call about?"
  },
  {
    "Index": 13,
    "Start Time": "00:00:32,140",
    "End Time": "00:00:33,540",
    "Speaker": "SPEAKER_01",
    "Text": "What are you smoking up?"
  },
  {
    "Index": 14,
    "Start Time": "00:00:33,920",
    "End Time": "00:00:34,000",
    "Speaker": "SPEAKER_00",
    "Text": "What?"
  },
  {
    "Index": 15,
    "Start Time": "00:00:35,920",
    "End Time": "00:00:38,320",
    "Speaker": "SPEAKER_01",
    "Text": "Oh, this is no one doing up there."
  },
  {
    "Index": 16,
    "Start Time": "00:00:38,600",
    "End Time": "00:00:40,260",
    "Speaker": "SPEAKER_01",
    "Text": "See if you want to go pray with me."
  },
  {
    "Index": 17,
    "Start Time": "00:00:40,400",
    "End Time": "00:00:42,940",
    "Speaker": "SPEAKER_01",
    "Text": "We've got a rabbit supper coming up on Friday night."
  },
  {
    "Index": 18,
    "Start Time": "00:00:44,160",
    "End Time": "00:00:44,980",
    "Speaker": "SPEAKER_00",
    "Text": "Where's it going to be?"
  },
  {
    "Index": 19,
    "Start Time": "00:00:45,880",
    "End Time": "00:00:48,000",
    "Speaker": "SPEAKER_01",
    "Text": "It's going to be there in town on Friday night."
  },
  {
    "Index": 20,
    "Start Time": "00:00:48,100",
    "End Time": "00:00:49,860",
    "Speaker": "SPEAKER_01",
    "Text": "They got a bunch of rabbits cooked up."
  },
  {
    "Index": 21,
    "Start Time": "00:00:49,980",
    "End Time": "00:00:50,500",
    "Speaker": "SPEAKER_01",
    "Text": "Oh, boy."
  },
  {
    "Index": 22,
    "Start Time": "00:00:50,780",
    "End Time": "00:00:51,980",
    "Speaker": "SPEAKER_01",
    "Text": "They got them cooking up."
  },
  {
    "Index": 23,
    "Start Time": "00:00:52,180",
    "End Time": "00:00:53,800",
    "Speaker": "SPEAKER_01",
    "Text": "They're real hard, real hot, real hot, real hot."
  },
  {
    "Index": 24,
    "Start Time": "00:00:54,620",
    "End Time": "00:00:56,000",
    "Speaker": "SPEAKER_01",
    "Text": "I can go with you."
  },
  {
    "Index": 25,
    "Start Time": "00:00:57,280",
    "End Time": "00:00:58,080",
    "Speaker": "SPEAKER_00",
    "Text": "Where's you going to be?"
  },
  {
    "Index": 26,
    "Start Time": "00:00:58,560",
    "End Time": "00:00:59,940",
    "Speaker": "SPEAKER_01",
    "Text": "It's going to be up in town."
  },
  {
    "Index": 27,
    "Start Time": "00:01:00,000",
    "End Time": "00:01:00,220",
    "Speaker": "SPEAKER_01",
    "Text": "there."
  },
  {
    "Index": 28,
    "Start Time": "00:01:01,040",
    "End Time": "00:01:01,460",
    "Speaker": "SPEAKER_00",
    "Text": "In town?"
  },
  {
    "Index": 29,
    "Start Time": "00:01:02,280",
    "End Time": "00:01:03,220",
    "Speaker": "SPEAKER_00",
    "Text": "Laco's a big place."
  },
  {
    "Index": 30,
    "Start Time": "00:01:03,540",
    "End Time": "00:01:03,700",
    "Speaker": "SPEAKER_01",
    "Text": "Yeah."
  },
  {
    "Index": 31,
    "Start Time": "00:01:05,540",
    "End Time": "00:01:07,180",
    "Speaker": "SPEAKER_00",
    "Text": "Is it at the jail or where is it?"
  },
  {
    "Index": 32,
    "Start Time": "00:01:07,560",
    "End Time": "00:01:07,740",
    "Speaker": "SPEAKER_01",
    "Text": "Yeah."
  },
  {
    "Index": 33,
    "Start Time": "00:01:08,540",
    "End Time": "00:01:09,240",
    "Speaker": "SPEAKER_00",
    "Text": "City Hall?"
  },
  {
    "Index": 34,
    "Start Time": "00:01:09,660",
    "End Time": "00:01:09,800",
    "Speaker": "SPEAKER_01",
    "Text": "Yeah."
  },
  {
    "Index": 35,
    "Start Time": "00:01:11,400",
    "End Time": "00:01:13,260",
    "Speaker": "SPEAKER_00",
    "Text": "Maybe you better call back when you're sober."
