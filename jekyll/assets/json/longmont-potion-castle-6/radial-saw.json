[
  {
    "Index": 1,
    "Start Time": "00:00:00,000",
    "End Time": "00:00:02,000",
    "Speaker": "Man",
    "Text": "I got explaining to do."
  },
  {
    "Index": 2,
    "Start Time": "00:00:02,000",
    "End Time": "00:00:03,000",
    "Speaker": "LPC",
    "Text": "You heard me."
  },
  {
    "Index": 3,
    "Start Time": "00:00:03,000",
    "End Time": "00:00:05,000",
    "Speaker": "Man",
    "Text": "I don't even know you."
  },
  {
    "Index": 4,
    "Start Time": "00:00:05,000",
    "End Time": "00:00:08,000",
    "Speaker": "LPC",
    "Text": "[sigh] You better believe you do, buster."
  },
  {
    "Index": 5,
    "Start Time": "00:00:08,000",
    "End Time": "00:00:10,000",
    "Speaker": "Man",
    "Text": "Who are you calling?"
  },
  {
    "Index": 6,
    "Start Time": "00:00:10,000",
    "End Time": "00:00:12,000",
    "Speaker": "LPC",
    "Text": "I'm tryin'a get some work done over here."
  },
  {
    "Index": 7,
    "Start Time": "00:00:12,000",
    "End Time": "00:00:14,000",
    "Speaker": "Man",
    "Text": "Work done where?"
  },
  {
    "Index": 8,
    "Start Time": "00:00:14,000",
    "End Time": "00:00:17,000",
    "Speaker": "LPC",
    "Text": "Listen to me, bucko. Don't be double talkin'."
  },
  {
    "Index": 9,
    "Start Time": "00:00:17,000",
    "End Time": "00:00:19,000",
    "Speaker": "Man",
    "Text": "What work are you talking about?"
  },
  {
    "Index": 10,
    "Start Time": "00:00:19,000",
    "End Time": "00:00:21,000",
    "Speaker": "LPC",
    "Text": "I'm workin' with a radial saw, mister."
  },
  {
    "Index": 11,
    "Start Time": "00:00:21,000",
    "End Time": "00:00:23,000",
    "Speaker": "Man",
    "Text": "A who?"
  },
  {
    "Index": 12,
    "Start Time": "00:00:23,000",
    "End Time": "00:00:26,000",
    "Speaker": "LPC",
    "Text": "Radio sound, you woke me up."
  },
  {
    "Index": 13,
    "Start Time": "00:00:26,000",
    "End Time": "00:00:28,000",
    "Speaker": "Man",
    "Text": "I woke you up?"
  },
  {
    "Index": 14,
    "Start Time": "00:00:28,000",
    "End Time": "00:00:29,000",
    "Speaker": "LPC",
    "Text": "That's right."
  },
  {
    "Index": 15,
    "Start Time": "00:00:29,000",
    "End Time": "00:00:31,000",
    "Speaker": "LPC",
    "Text": "Now you wash out, sucker."
  },
  {
    "Index": 16,
    "Start Time": "00:00:31,000",
    "End Time": "00:00:35,000",
    "Speaker": "Woman",
    "Text": "Who are you trying to call, talk to?"
  },
  {
    "Index": 17,
    "Start Time": "00:00:35,000",
    "End Time": "00:00:37,000",
    "Speaker": "LPC",
    "Text": "You. Your... your husband."
  },
  {
    "Index": 18,
    "Start Time": "00:00:37,000",
    "End Time": "00:00:39,000",
    "Speaker": "Woman",
    "Text": "My husband. You wanna talk to my husband?"
  },
  {
    "Index": 19,
    "Start Time": "00:00:39,000",
    "End Time": "00:00:40,000",
    "Speaker": "LPC",
    "Text": "Yes."
  },
  {
    "Index": 20,
    "Start Time": "00:00:40,000",
    "End Time": "00:00:41,000",
    "Speaker": "Man",
    "Text": "Hello."
  },
  {
    "Index": 21,
    "Start Time": "00:00:41,000",
    "End Time": "00:00:43,000",
    "Speaker": "LPC",
    "Text": "What's up, man?"
  },
  {
    "Index": 22,
    "Start Time": "00:00:43,000",
    "End Time": "00:00:44,000",
    "Speaker": "Man",
    "Text": "Huh?"
  },
  {
    "Index": 23,
    "Start Time": "00:00:44,000",
    "End Time": "00:00:45,000",
    "Speaker": "LPC",
    "Text": "What's up?"
  },
  {
    "Index": 24,
    "Start Time": "00:00:45,000",
    "End Time": "00:00:46,000",
    "Speaker": "Man",
    "Text": "Uh, well, who are you, anyway?"
  },
  {
    "Index": 25,
    "Start Time": "00:00:46,000",
    "End Time": "00:00:47,000",
    "Speaker": "LPC",
    "Text": "Nigel."
  },
  {
    "Index": 26,
    "Start Time": "00:00:47,000",
    "End Time": "00:00:49,000",
    "Speaker": "Man",
    "Text": "And what's your last name?"
  },
  {
    "Index": 27,
    "Start Time": "00:00:49,000",
    "End Time": "00:00:51,000",
    "Speaker": "SPEAKER_03",
    "Text": "This is that it?"
  },
  {
    "Index": 28,
    "Start Time": "00:00:51,000",
    "End Time": "00:00:52,000",
    "Speaker": "Man",
    "Text": "You've got the wrong number."
  },
  {
    "Index": 29,
    "Start Time": "00:00:52,000",
    "End Time": "00:00:53,000",
    "Speaker": "LPC",
    "Text": "No, I don't, man."
  },
  {
    "Index": 30,
    "Start Time": "00:00:53,000",
    "End Time": "00:00:55,000",
    "Speaker": "Man",
    "Text": "What number did you call?"
  },
  {
    "Index": 31,
    "Start Time": "00:00:55,000",
    "End Time": "00:00:58,000",
    "Speaker": "LPC",
    "Text": "2-2-17-13, mister."
  },
  {
    "Index": 32,
    "Start Time": "00:00:58,000",
    "End Time": "00:00:59,000",
    "Speaker": "LPC",
    "Text": "How does that grab you?"
  },
  {
    "Index": 33,
    "Start Time": "00:00:59,000",
    "End Time": "00:01:09,000",
    "Speaker": "Man",
    "Text": "Well, uh, you don't, uh, you're... you're... y... you just don't, uh, like, uh... duh, ya... ya... you don't sound like a friend of mine, or any relation of mine, or anything."
  },
  {
    "Index": 34,
    "Start Time": "00:01:09,000",
    "End Time": "00:01:12,000",
    "Speaker": "LPC",
    "Text": "How would you like it if I grabbed hold of you?"
  },
  {
    "Index": 35,
    "Start Time": "00:01:12,000",
    "End Time": "00:01:15,000",
    "Speaker": "Man",
    "Text": "You son of a bitch."
  }
]
